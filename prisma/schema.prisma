generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  sessions     Session[]
  profile      Profile[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Profile {
  id                          String                        @id @default(cuid())
  username                    String                        @unique
  userId                      String                        @unique
  user                        User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkFavoriteNovels          LinkFavoriteNovel[]
  linkWatchLaterNovels        LinkWatchLaterNovel[]
  linkNotificationNovels      LinkNotificationNovel[]
  chapterComments             ChapterComment[]
  novelComments               NovelComment[]
  novelCommentReplies         NovelCommentReply[]
  linkNovelCommentLikes       LinkNovelCommentLike[]
  linkNovelCommentReplyLikes  LinkNovelCommentReplyLikes[]
  chapterCommentReply         ChapterCommentReply[]
  linkChapterCommentReplyLike LinkChapterCommentReplyLike[]
  LinkChapterCommentLike      LinkChapterCommentLike[]
  ChapterView                 ChapterView[]

  @@index([userId])
}

model Novel {
  id                     String                  @id @default(cuid())
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  title                  String                  @unique
  description            String
  coverImg               String
  // TODO Rating 
  rating                 Int
  ratingCount            Int
  chapters               Chapter[]
  linkTypeNovels         LinkTypeNovel[]
  linkFavoriteNovels     LinkFavoriteNovel[]
  comments               NovelComment[]
  recommendations        NovelRecommendation[]   @relation("TargetNovel")
  recommendedIn          NovelRecommendation[]   @relation("RecommendedNovel")
  linkWatchLaterNovels   LinkWatchLaterNovel[]
  linkNotificationNovels LinkNotificationNovel[]
  lastChapterCreatedAt   DateTime?
  LastChapter            LastChapter?
}

model LastChapter {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  number    Int
  novelId   String   @unique
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@index([novelId])
}

model Chapter {
  id          String           @id @default(cuid())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  title       String
  number      Int
  content     String
  novelId     String
  novel       Novel            @relation(fields: [novelId], references: [id], onDelete: Cascade)
  comment     ChapterComment[]
  ChapterView ChapterView[]

  @@unique([novelId, number])
  @@index([novelId])
}

model ChapterView {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profileId String?
  profile   Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  chapterId String
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([chapterId])
}

model LinkFavoriteNovel {
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  novelId   String
  novel     Novel   @relation(fields: [novelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([profileId, novelId])
  @@index([profileId])
  @@index([novelId])
}

model LinkWatchLaterNovel {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  novelId   String
  novel     Novel   @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([novelId])
}

model LinkNotificationNovel {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  novelId   String
  novel     Novel   @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([novelId])
}

model NovelRecommendation {
  recommendedNovelId   String
  recommendedNovel     Novel  @relation("RecommendedNovel", fields: [recommendedNovelId], references: [id], onDelete: Cascade)
  userWhoRecommendName String
  content              String

  targetNovelId String
  targetNovel   Novel  @relation("TargetNovel", fields: [targetNovelId], references: [id], onDelete: Cascade)

  @@id([recommendedNovelId, targetNovelId])
  @@index([recommendedNovelId])
  @@index([targetNovelId])
}

model LinkTypeNovel {
  id      String @id @default(cuid())
  novelId String
  novel   Novel  @relation(fields: [novelId], references: [id])
  typeId  String
  type    Type   @relation(fields: [typeId], references: [id])

  @@index([novelId])
  @@index([typeId])
}

model Type {
  id             String          @id @default(cuid())
  name           String
  linkTypeNovels LinkTypeNovel[]
}

//////////Chapter Comments

model ChapterComment {
  id                     String                   @id @default(cuid())
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  content                String
  profileId              String
  profile                Profile                  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  chapterId              String
  chapter                Chapter                  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  chapterCommentReply    ChapterCommentReply[]
  LinkChapterCommentLike LinkChapterCommentLike[]

  @@index([profileId])
  @@index([chapterId])
}

model LinkChapterCommentLike {
  id               String         @id @default(cuid())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  profileId        String
  profile          Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  chapterCommentId String
  chapterComment   ChapterComment @relation(fields: [chapterCommentId], references: [id], onDelete: Cascade)

  @@unique([profileId, chapterCommentId])
  @@index([profileId])
  @@index([chapterCommentId])
}

model ChapterCommentReply {
  id                          String                        @id @default(cuid())
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime                      @updatedAt
  content                     String
  profileId                   String
  profile                     Profile                       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  chapterCommentId            String
  chapterComment              ChapterComment                @relation(fields: [chapterCommentId], references: [id], onDelete: Cascade)
  replyTo                     String?
  linkChapterCommentReplyLike LinkChapterCommentReplyLike[]

  @@index([profileId])
  @@index([chapterCommentId])
}

model LinkChapterCommentReplyLike {
  id                    String              @id @default(cuid())
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  profileId             String
  profile               Profile             @relation(fields: [profileId], references: [id], onDelete: Cascade)
  chapterCommentReplyId String
  chapterCommentReply   ChapterCommentReply @relation(fields: [chapterCommentReplyId], references: [id], onDelete: Cascade)

  @@unique([profileId, chapterCommentReplyId])
  @@index([profileId])
  @@index([chapterCommentReplyId])
}

//////////Novel Comments

model NovelComment {
  id                    String                 @id @default(cuid())
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  content               String
  profileId             String
  profile               Profile                @relation(fields: [profileId], references: [id], onDelete: Cascade)
  novelId               String
  novel                 Novel                  @relation(fields: [novelId], references: [id], onDelete: Cascade)
  novelCommentReplys    NovelCommentReply[]
  linkNovelCommentLikes LinkNovelCommentLike[]

  @@index([profileId])
  @@index([novelId])
}

model LinkNovelCommentLike {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  profileId      String
  profile        Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  novelCommentId String
  novelComment   NovelComment @relation(fields: [novelCommentId], references: [id], onDelete: Cascade)

  @@unique([profileId, novelCommentId])
  @@index([profileId])
  @@index([novelCommentId])
}

model NovelCommentReply {
  id                         String                       @id @default(cuid())
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt
  content                    String
  profileId                  String
  profile                    Profile                      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  novelcommentId             String
  novelComment               NovelComment                 @relation(fields: [novelcommentId], references: [id], onDelete: Cascade)
  replyTo                    String?
  linkNovelCommentReplyLikes LinkNovelCommentReplyLikes[]

  @@index([profileId])
  @@index([novelcommentId])
}

model LinkNovelCommentReplyLikes {
  id                  String            @id @default(cuid())
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  profileId           String
  profile             Profile           @relation(fields: [profileId], references: [id], onDelete: Cascade)
  novelCommentReplyId String
  novelCOmmentReply   NovelCommentReply @relation(fields: [novelCommentReplyId], references: [id], onDelete: Cascade)

  @@unique([profileId, novelCommentReplyId])
  @@index([profileId])
  @@index([novelCommentReplyId])
}
